{
  "name": "career-copilot",
  "version": "0.1.0",
  "description": "AI assistant that drafts tailored cover letters and answers job-application questions from your full career history.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "test": "vitest run",
    "package": "npm run build && mkdir -p release && rm -f release/career-copilot-v$npm_package_version.zip && cd dist && zip -rq -X ../release/career-copilot-v$npm_package_version.zip . -x '.*'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "openai": "^6.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.3",
    "vitest": "^4.1.9"
  }
}
